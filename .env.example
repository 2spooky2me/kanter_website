# Frontend
# In production leave this empty when Nginx proxies /api to the Node server.
# For development you can use: REACT_APP_API_URL=http://localhost:4000
REACT_APP_API_URL=

# Backend
API_HOST=0.0.0.0
API_PORT=4000

# Create strong values before first production start.
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
ADMIN_TOKEN_SECRET=change-this-to-a-long-random-secret
